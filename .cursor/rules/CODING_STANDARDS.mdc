## Frontend Standards

### Recommended Tech Stack
| Purpose | Tool |
|---------|------|
| Framework | React |
| Language | TypeScript (Strict mode) |
| Styling | CSS Modules |
| State | React Hooks, Context, or Redux (if needed) |

### Layer Responsibilities

| Layer | Responsibility | Forbidden |
|-------|----------------|--------------|
| **Models** | TypeScript interface definitions | Logic |
| **API** | HTTP calls, authentication | Business logic |
| **Hooks** | State management, API orchestration, loading/error | JSX/UI rendering |
| **Components** | Pure UI rendering | API calls, business logic |
| **Pages** | Route composition, layout | Heavy logic |

### Import Order (Strict)
```typescript
// 1. External packages (React, libraries)
import React, { useState, useCallback } from 'react';
import { useNavigate } from 'react-router-dom';

// 2. Internal modules (use path aliases like ~/ or @/)
import { User } from '~/models';
import { useUser } from '~/hooks';
import { Button } from '~/components/common';

// 3. Relative imports (same feature)
import { UserCard } from './UserCard';

// 4. Styles (always last)
import styles from './MyComponent.module.css';
```

### Naming Conventions
| Type | Convention | Example |
|------|------------|---------|
| Interfaces/Types | PascalCase | `UserProfile`, `ApiResponse` |
| Variables/Functions | camelCase | `userData`, `fetchUser` |
| Components | PascalCase | `UserCard`, `LoginForm` |
| CSS Classes | camelCase | `styles.cardHeader` |
| Event Handlers | `on{Action}` | `onClick`, `onSubmit` |
| Boolean Props | `is{State}` or `has{Property}` | `isLoading`, `hasError` |

### Model Example
```typescript
// src/models/user.ts

export interface User {
  id: number;
  email: string;
  name: string;
  createdAt: string | null;  // Use | null, NOT Optional<>
}

export interface UserRequest {
  email: string;
  name: string;
}

// Use type[] NOT Array<type>
export interface UserListResponse {
  users: User[];
  total: number;
}
```

### API Layer Example
```typescript
// src/api/userApi.ts

import { User, UserRequest } from '~/models';

export async function createUser(
  token: string,  // Auth token as FIRST parameter
  request: UserRequest
): Promise<User> {
  // HTTP concerns only - no business logic
  const response = await fetch('/api/users', {
    method: 'POST',
    headers: {
      'Content-Type': 'application/json',
      'Authorization': `Bearer ${token}`,
    },
    body: JSON.stringify(request),
  });
  
  if (!response.ok) {
    throw new ApiError(response.status, await response.text());
  }
  
  return response.json();
}
```

### Hook Example
```typescript
// src/hooks/useUser.ts

import { useState, useCallback } from 'react';
import { useAuth } from '~/hooks/useAuth';
import { createUser } from '~/api/userApi';
import { User, UserRequest } from '~/models';

export function useUser() {
  const { getToken } = useAuth();
  const [data, setData] = useState<User | null>(null);
  const [isLoading, setIsLoading] = useState(false);
  const [error, setError] = useState<string | null>(null);
  
  // Wrap handlers in useCallback for stable references
  const create = useCallback(async (request: UserRequest) => {
    setIsLoading(true);
    setError(null);
    
    const token = await getToken();
    const result = await createUser(token, request);
    setData(result);
    setIsLoading(false);
  }, [getToken]);
  
  return { data, isLoading, error, create };
}
```

### Component Example
```typescript
// src/components/UserCard/UserCard.tsx

import styles from './UserCard.module.css';

interface UserCardProps {
  name: string;
  email: string;
  onEdit: () => void;
  isActive: boolean;
}

// Named export - NO default exports
export function UserCard({ name, email, onEdit, isActive }: UserCardProps) {
  // PURE UI - No API calls, no business logic
  return (
    <div className={styles.root}>
      <h3 className={styles.name}>{name}</h3>
      <p className={styles.email}>{email}</p>
      <span className={isActive ? styles.active : styles.inactive}>
        {isActive ? 'Active' : 'Inactive'}
      </span>
      <button onClick={onEdit}>Edit</button>
    </div>
  );
}
```

