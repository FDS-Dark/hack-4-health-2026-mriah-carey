## 💡 Common Mistakes to Avoid

### 1. Business Logic in the Wrong Place
```typescript
// BAD: Logic in component
function UserList() {
  const [users, setUsers] = useState([]);
  
  // This belongs in a hook or service!
  const activeUsers = users.filter(u => u.status === 'active' && u.lastLogin > Date.now() - 86400000);
  
  return <ul>{activeUsers.map(u => <li>{u.name}</li>)}</ul>;
}

// GOOD: Logic in hook
function UserList() {
  const { activeUsers } = useActiveUsers();
  return <ul>{activeUsers.map(u => <li>{u.name}</li>)}</ul>;
}
```

### 2. API Calls in Components
```typescript
// BAD: API call in component
function UserProfile({ userId }) {
  const [user, setUser] = useState(null);
  
  useEffect(() => {
    fetch(`/api/users/${userId}`).then(r => r.json()).then(setUser);
  }, [userId]);
  
  return <div>{user?.name}</div>;
}

// GOOD: API call in hook
function UserProfile({ userId }) {
  const { user, isLoading } = useUser(userId);
  
  if (isLoading) return <Spinner />;
  return <div>{user?.name}</div>;
}
```

### 3. Over-Engineering
```python
# BAD: Unnecessary abstraction
class UserRepositoryInterface(ABC):
    @abstractmethod
    def get_user(self, id: int) -> User: ...

class UserRepository(UserRepositoryInterface):
    def get_user(self, id: int) -> User:
        return self.db.query(User).get(id)

# GOOD: Simple and direct (when you only have one implementation)
class UserDatabridge:
    def get_user(self, id: int) -> User:
        return self.db.query(User).get(id)
```

### 4. Excessive Error Handling
```python
# ❌ BAD: Catching just to re-raise
@router.post("/users")
async def create_user(request: UserRequest):
    try:
        return await service.create_user(request)
    except Exception as e:
        raise HTTPException(500, str(e))

# GOOD: handle all errors the same way
@router.post("/users")
@handle_error() 
async def create_user(request: UserRequest):
    return await service.create_user(request)
```

